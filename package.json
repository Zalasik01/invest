{
  "name": "invest-bot",
  "version": "1.0.0",
  "description": "Bot Telegram de investimentos com Gemini AI - Assistente focado em renda passiva mensal",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "concurrently \"npm run d:server\" \"npm run d:client\"",
    "d:server": "node index.js",
    "d:client": "vite",
    "build": "vite build",
    "webhook:setup": "node scripts/configurarWebhook.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "investimentos",
    "gemini",
    "ai"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.99.1",
    "cross-fetch": "^4.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "node-telegram-bot-api": "^0.67.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.0"
  }
}
